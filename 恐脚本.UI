page2:AddButton({
    Text = "甩飞全部人",
    Callback = function()
        game:GetService("StarterGui"):SetCore("SendNotification", {Title = "甩飞", Text = "开始甩飞所有玩家...", Duration = 3})
        task.spawn(function()
            local count = 0
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    powerfulFling(p)
                    count = count + 1
                    task.wait(0.5)
                end
            end
            game:GetService("StarterGui"):SetCore("SendNotification", {Title = "甩飞完成", Text = "共甩飞 " .. tostring(count) .. " 个玩家", Duration = 3})
        end)
    end
})

page2:AddButton({
    Text = "甩飞最近的人",
    Callback = function()
        local nearest = nil
        local minDist = math.huge
        local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position
        if not myPos then
            game:GetService("StarterGui"):SetCore("SendNotification", {Title = "甩飞", Text = "你的角色未加载", Duration = 3})
            return
        end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (p.Character.HumanoidRootPart.Position - myPos).Magnitude
                if dist < minDist then minDist = dist; nearest = p end
            end
        end
        if nearest then
            game:GetService("StarterGui"):SetCore("SendNotification", {Title = "甩飞", Text = "正在甩飞 " .. nearest.Name, Duration = 3})
            task.spawn(function() powerfulFling(nearest) end)
        else
            game:GetService("StarterGui"):SetCore("SendNotification", {Title = "甩飞", Text = "未找到其他玩家", Duration = 3})
        end
    end
})

