function Page:CreateSavedServersPanel(config)
    local mainFrame = self:GetMain()
    local panel = Instance.new("Frame")
    panel.Name = "SavedServersPanel"
    panel.Parent = mainFrame
    panel.BackgroundColor3 = self.theme.PanelBg
    panel.BackgroundTransparency = 0.2
    panel.Visible = false
    panel.ZIndex = 200
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = panel
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = self.theme.PanelStroke
    stroke.Parent = panel
    local title = Instance.new("TextLabel")
    title.Parent = panel
    title.Size = UDim2.new(1, 0, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = config.Title or "已保存的服务器"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Parent = panel
    scrollFrame.Size = UDim2.new(1, -10, 1, -80)
    scrollFrame.Position = UDim2.new(0, 5, 0, 35)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 4
    local servers = config.Servers or {}
    local function refreshList()
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        local y = 0
        for _, entry in ipairs(servers) do
            local row = Instance.new("Frame")
            row.Parent = scrollFrame
            row.Size = UDim2.new(1, -10, 0, 30)
            row.Position = UDim2.new(0, 5, 0, y)
            row.BackgroundTransparency = 1
            local idLabel = Instance.new("TextLabel")
            idLabel.Parent = row
            idLabel.Size = UDim2.new(0, 140, 1, 0)
            idLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            idLabel.Text = entry.name .. " (" .. entry.id:sub(1, 10) .. "...)"
            idLabel.TextColor3 = Color3.new(1, 1, 1)
            idLabel.Font = Enum.Font.SourceSans
            idLabel.TextSize = 12
            local idCorner = Instance.new("UICorner")
            idCorner.CornerRadius = UDim.new(0, 4)
            idCorner.Parent = idLabel
            local tpBtn = Instance.new("TextButton")
            tpBtn.Parent = row
            tpBtn.Size = UDim2.new(0, 35, 1, 0)
            tpBtn.Position = UDim2.new(0, 145, 0, 0)
            tpBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            tpBtn.Text = "传"
            tpBtn.TextColor3 = Color3.new(1, 1, 1)
            tpBtn.Font = Enum.Font.SourceSansBold
            tpBtn.TextSize = 12
            local tpCorner = Instance.new("UICorner")
            tpCorner.CornerRadius = UDim.new(0, 4)
            tpCorner.Parent = tpBtn
            tpBtn.MouseButton1Click:Connect(function()
                if config.OnTeleport then config.OnTeleport(entry.id) end
            end)
            local renameBtn = Instance.new("TextButton")
            renameBtn.Parent = row
            renameBtn.Size = UDim2.new(0, 40, 1, 0)
            renameBtn.Position = UDim2.new(0, 183, 0, 0)
            renameBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 200)
            renameBtn.Text = "改名"
            renameBtn.TextColor3 = Color3.new(1, 1, 1)
            renameBtn.Font = Enum.Font.SourceSansBold
            renameBtn.TextSize = 11
            local renameCorner = Instance.new("UICorner")
            renameCorner.CornerRadius = UDim.new(0, 4)
            renameCorner.Parent = renameBtn
            renameBtn.MouseButton1Click:Connect(function()
                local renamePanel = Instance.new("Frame")
                renamePanel.Parent = panel
                renamePanel.Size = UDim2.new(0, 200, 0, 60)
                renamePanel.Position = UDim2.new(0.5, -100, 0.5, -30)
                renamePanel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                renamePanel.ZIndex = 300
                local rc = Instance.new("UICorner")
                rc.CornerRadius = UDim.new(0, 8)
                rc.Parent = renamePanel
                local input = Instance.new("TextBox")
                input.Parent = renamePanel
                input.Size = UDim2.new(1, -20, 0, 25)
                input.Position = UDim2.new(0, 10, 0, 5)
                input.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                input.Text = entry.name
                input.TextColor3 = Color3.new(1, 1, 1)
                input.Font = Enum.Font.SourceSans
                input.TextSize = 14
                local inputCorner = Instance.new("UICorner")
                inputCorner.CornerRadius = UDim.new(0, 4)
                inputCorner.Parent = input
                local confirmBtn = Instance.new("TextButton")
                confirmBtn.Parent = renamePanel
                confirmBtn.Size = UDim2.new(0, 60, 0, 22)
                confirmBtn.Position = UDim2.new(0, 10, 0, 33)
                confirmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                confirmBtn.Text = "确定"
                confirmBtn.TextColor3 = Color3.new(1, 1, 1)
                confirmBtn.Font = Enum.Font.SourceSansBold
                confirmBtn.TextSize = 13
                local cfCorner = Instance.new("UICorner")
                cfCorner.CornerRadius = UDim.new(0, 4)
                cfCorner.Parent = confirmBtn
                local cancelBtn = Instance.new("TextButton")
                cancelBtn.Parent = renamePanel
                cancelBtn.Size = UDim2.new(0, 60, 0, 22)
                cancelBtn.Position = UDim2.new(0, 80, 0, 33)
                cancelBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                cancelBtn.Text = "取消"
                cancelBtn.TextColor3 = Color3.new(1, 1, 1)
                cancelBtn.Font = Enum.Font.SourceSansBold
                cancelBtn.TextSize = 13
                local clCorner = Instance.new("UICorner")
                clCorner.CornerRadius = UDim.new(0, 4)
                clCorner.Parent = cancelBtn
                confirmBtn.MouseButton1Click:Connect(function()
                    if config.OnRename then
                        config.OnRename(entry.id, input.Text)
                    end
                    for _, s in ipairs(servers) do
                        if s.id == entry.id then
                            s.name = input.Text
                            break
                        end
                    end
                    refreshList()
                    renamePanel:Destroy()
                end)
                cancelBtn.MouseButton1Click:Connect(function() renamePanel:Destroy() end)
            end)
            local delBtn = Instance.new("TextButton")
            delBtn.Parent = row
            delBtn.Size = UDim2.new(0, 35, 1, 0)
            delBtn.Position = UDim2.new(0, 226, 0, 0)
            delBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            delBtn.Text = "删"
            delBtn.TextColor3 = Color3.new(1, 1, 1)
            delBtn.Font = Enum.Font.SourceSansBold
            delBtn.TextSize = 12
            local delCorner = Instance.new("UICorner")
            delCorner.CornerRadius = UDim.new(0, 4)
            delCorner.Parent = delBtn
            delBtn.MouseButton1Click:Connect(function()
                if config.OnDelete then
                    config.OnDelete(entry.id)
                end
                for i = #servers, 1, -1 do
                    if servers[i].id == entry.id then
                        table.remove(servers, i)
                        break
                    end
                end
                refreshList()
            end)
            y = y + 35
        end
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(y, 100))
    end
    local saveCurrentBtn = Instance.new("TextButton")
    saveCurrentBtn.Parent = panel
    saveCurrentBtn.Size = UDim2.new(1, -20, 0, 30)
    saveCurrentBtn.Position = UDim2.new(0, 10, 1, -40)
    saveCurrentBtn.BackgroundColor3 = self.theme.CopyBtn
    saveCurrentBtn.Text = "保存当前服务器"
    saveCurrentBtn.TextColor3 = Color3.new(1, 1, 1)
    saveCurrentBtn.Font = Enum.Font.SourceSansBold
    saveCurrentBtn.TextSize = 14
    local saveCorner = Instance.new("UICorner")
    saveCorner.CornerRadius = UDim.new(0, 6)
    saveCorner.Parent = saveCurrentBtn
    saveCurrentBtn.MouseButton1Click:Connect(function()
        local namePanel = Instance.new("Frame")
        namePanel.Parent = panel
        namePanel.Size = UDim2.new(0, 200, 0, 60)
        namePanel.Position = UDim2.new(0.5, -100, 0.5, -30)
        namePanel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        namePanel.ZIndex = 300
        local nc = Instance.new("UICorner")
        nc.CornerRadius = UDim.new(0, 8)
        nc.Parent = namePanel
        local input = Instance.new("TextBox")
        input.Parent = namePanel
        input.Size = UDim2.new(1, -20, 0, 25)
        input.Position = UDim2.new(0, 10, 0, 5)
        input.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        input.Text = "我的服务器 " .. (#servers + 1)
        input.TextColor3 = Color3.new(1, 1, 1)
        input.Font = Enum.Font.SourceSans
        input.TextSize = 14
        local ic = Instance.new("UICorner")
        ic.CornerRadius = UDim.new(0, 4)
        ic.Parent = input
        local confirmBtn = Instance.new("TextButton")
        confirmBtn.Parent = namePanel
        confirmBtn.Size = UDim2.new(0, 60, 0, 22)
        confirmBtn.Position = UDim2.new(0, 10, 0, 33)
        confirmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        confirmBtn.Text = "保存"
        confirmBtn.TextColor3 = Color3.new(1, 1, 1)
        confirmBtn.Font = Enum.Font.SourceSansBold
        confirmBtn.TextSize = 13
        local cf = Instance.new("UICorner")
        cf.CornerRadius = UDim.new(0, 4)
        cf.Parent = confirmBtn
        local cancelBtn = Instance.new("TextButton")
        cancelBtn.Parent = namePanel
        cancelBtn.Size = UDim2.new(0, 60, 0, 22)
        cancelBtn.Position = UDim2.new(0, 80, 0, 33)
        cancelBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        cancelBtn.Text = "取消"
        cancelBtn.TextColor3 = Color3.new(1, 1, 1)
        cancelBtn.Font = Enum.Font.SourceSansBold
        cancelBtn.TextSize = 13
        local cl = Instance.new("UICorner")
        cl.CornerRadius = UDim.new(0, 4)
        cl.Parent = cancelBtn
        confirmBtn.MouseButton1Click:Connect(function()
            if config.OnSave then
                config.OnSave(game.JobId, input.Text)
            end
            table.insert(servers, {id = game.JobId, name = input.Text})
            refreshList()
            namePanel:Destroy()
        end)
        cancelBtn.MouseButton1Click:Connect(function() namePanel:Destroy() end)
    end)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = panel
    closeBtn.Size = UDim2.new(0, 22, 0, 22)
    closeBtn.Position = UDim2.new(1, -26, 0, 6)
    closeBtn.BackgroundColor3 = self.theme.CloseBtn
    closeBtn.Text = "X"
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.SourceSansBold
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() tweenPanelClose(panel) end)
    panel:GetPropertyChangedSignal("Visible"):Connect(function()
        if panel.Visible then refreshList() end
    end)
    return panel
end

