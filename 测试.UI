    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() tweenPanelClose(panel) end)
    local function updateIdDisplay()
        idLabel.Text = "ID: " .. game.JobId
    end
    copyBtn.MouseButton1Click:Connect(function()
        if config.OnCopy then config.OnCopy(game.JobId) end
    end)
    saveBtn.MouseButton1Click:Connect(function()
        if config.OnSave then config.OnSave(game.JobId) end
    end)
    panel:GetPropertyChangedSignal("Visible"):Connect(function()
        if panel.Visible then updateIdDisplay() end
    end)
    return panel
end

function Page:AddInstanceIdPanel(config)
