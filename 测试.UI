local UILibrary = {}
UILibrary.__index = UILibrary

UILibrary.Defaults = {
    Theme = {
        MainBg = Color3.fromRGB(20, 20, 20),
        MainStroke = Color3.fromRGB(255, 0, 0),
        TopBar = Color3.fromRGB(30, 30, 30),
        ButtonBg = Color3.fromRGB(0, 0, 0),
        ButtonText = Color3.new(1, 1, 1),
        CatBg = Color3.fromRGB(25, 25, 25),
        CatActive = Color3.fromRGB(70, 70, 70),
        PanelBg = Color3.fromRGB(0, 0, 0),
        PanelStroke = Color3.fromRGB(100, 100, 100),
        SliderTrack = Color3.fromRGB(50, 50, 50),
        SliderFill = Color3.fromRGB(0, 120, 255),
        CloseBtn = Color3.fromRGB(200, 50, 50),
        ConfirmBtn = Color3.fromRGB(0, 180, 0),
        ResetBtn = Color3.fromRGB(180, 80, 0),
        CopyBtn = Color3.fromRGB(0, 120, 255),
    },
    Font = Enum.Font.SourceSansBold,
    TextSize = 14,
    CornerRadius = UDim.new(0, 6),
    ButtonCorner = UDim.new(0, 6),
    PanelCorner = UDim.new(0, 12),
    CloseCorner = UDim.new(0, 4),
    AnimationSpeed = 0.2,
}

function UILibrary:CreateCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or self.Defaults.CornerRadius
    corner.Parent = parent
    return corner
end

function UILibrary:CreateStroke(parent, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or self.Defaults.Theme.MainStroke
    stroke.Thickness = thickness or 2
    stroke.Parent = parent
    return stroke
end

local TweenService = game:GetService("TweenService")

local function tweenPanelOpen(panel, targetSize, targetPos)
    panel.Size = UDim2.new(0, 0, 0, 0)
    panel.Position = UDim2.new(targetPos.X.Scale, targetPos.X.Offset + targetSize.X.Offset / 2, targetPos.Y.Scale, targetPos.Y.Offset + targetSize.Y.Offset / 2)
    panel.Visible = true
    local tween = TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = targetSize,
        Position = targetPos
    })
    tween:Play()
end

local function tweenPanelClose(panel)
    local currentSize = panel.Size
    local currentPos = panel.Position
    local tween = TweenService:Create(panel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(currentPos.X.Scale, currentPos.X.Offset + currentSize.X.Offset / 2, currentPos.Y.Scale, currentPos.Y.Offset + currentSize.Y.Offset / 2)
    })
    tween:Play()
    tween.Completed:Connect(function()
        panel.Visible = false
        panel.Size = currentSize
        panel.Position = currentPos
    end)
end

local Page = {}
Page.__index = Page

function Page.new(parentScrollingFrame, theme)
    local self = setmetatable({}, Page)
    self.frame = Instance.new("Frame")
    self.frame.Parent = parentScrollingFrame
    self.frame.BackgroundTransparency = 1
    self.frame.Size = UDim2.new(1, 0, 1, 0)
    self.frame.Visible = false
    self.frame.ZIndex = 20
    self.buttonCount = 0
    self.theme = theme
    self.toggles = {}
    return self
end

function Page:GetMain()
    return self.frame.Parent.Parent.Parent
end

function Page:CalcPosition(index)
    local colWidth = 0.46
    local leftMargin = 0.03
    local spacingX = 0.04
    local rowHeight = 45
    local topMargin = 4
    local isLeft = (index % 2 == 1)
    local colIdx = isLeft and 0 or 1
    local rowIdx = math.floor((index - 1) / 2)
    local posXScale = leftMargin + colIdx * (colWidth + spacingX)
    local posYOffset = topMargin + rowIdx * rowHeight
    return UDim2.new(posXScale, 0, 0, posYOffset), UDim2.new(colWidth, 0, 0, 38)
end

function Page:UpdateCanvas()
    local maxY = 0
    for _, child in ipairs(self.frame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("Frame") then
            local bottom = child.Position.Y.Offset + child.Size.Y.Offset
            if bottom > maxY then maxY = bottom end
        end
    end
    if maxY == 0 then maxY = 100 end
    local scrollFrame = self.frame.Parent
    if scrollFrame and scrollFrame:IsA("ScrollingFrame") then
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, maxY + 20)
    end
end

function Page:AddButton(config)
    self.buttonCount = self.buttonCount + 1
    local pos, size = self:CalcPosition(self.buttonCount)
    local btn = Instance.new("TextButton")
    btn.Parent = self.frame
    btn.BackgroundColor3 = config.BgColor or self.theme.ButtonBg
    btn.BackgroundTransparency = 0.5
    btn.Size = size
    btn.Position = pos
    btn.Text = config.Text or "按钮"
    btn.TextColor3 = config.TextColor or self.theme.ButtonText
    btn.TextSize = config.TextSize or 14
    btn.AutoButtonColor = false
    btn.ZIndex = 21
    btn.Font = Enum.Font.SourceSansBold
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    local originalSize = size
    btn.MouseButton1Click:Connect(function()
        local tweenDown = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset * 0.92, originalSize.Y.Scale, originalSize.Y.Offset * 0.92)
        })
        tweenDown:Play()
        tweenDown.Completed:Connect(function()
            local tweenUp = TweenService:Create(btn, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = originalSize
            })
            tweenUp:Play()
        end)
        if config.Callback then
            config.Callback()
        end
    end)
    self:UpdateCanvas()
    return btn
end

function Page:AddToggle(config)
    local state = config.Default or false
    local ref = {}
    local text = config.Text or "开关"
    local btn = self:AddButton({
        Text = text .. "：" .. (state and "开" or "关"),
        Callback = function()
            state = not state
            ref[1].Text = text .. "：" .. (state and "开" or "关")
            if config.Callback then
                config.Callback(state)
            end
        end
    })
    ref[1] = btn
    self.toggles[text] = {Btn = btn, State = state, Ref = ref}
    return btn
end

function Page:AddSlider(config)
    local sliderPanel = nil
    local panelOpen = false
    local minVal = config.Min or 0
    local maxVal = config.Max or 100
    local defaultVal = config.Default or minVal
    local currentVal = defaultVal
    local text = config.Text or "滑块"
    local targetSize = UDim2.new(0, 250, 0, 160)
    local targetPos = UDim2.new(0.5, -125, 0.5, -80)
    local btn = self:AddButton({
        Text = text,
        Callback = function()
            if not sliderPanel then
                sliderPanel = self:CreateSliderPanel(config, minVal, maxVal, defaultVal, currentVal, function(val)
                    currentVal = val
                    if config.Callback then
                        config.Callback(val)
                    end
                end)
                sliderPanel.Size = targetSize
                sliderPanel.Position = targetPos
            end
            if not panelOpen then
                tweenPanelOpen(sliderPanel, targetSize, targetPos)
                panelOpen = true
            else
                tweenPanelClose(sliderPanel)
                panelOpen = false
            end
        end
    })
    return btn
end

function Page:CreateSliderPanel(config, minVal, maxVal, defaultVal, currentVal, onChange)
    local mainFrame = self:GetMain()
    local panel = Instance.new("Frame")
    panel.Name = config.Text .. "Panel"
    panel.Parent = mainFrame
    panel.BackgroundColor3 = self.theme.PanelBg
    panel.BackgroundTransparency = 0.2
    panel.Visible = false
    panel.ZIndex = 200
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = panel
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = self.theme.PanelStroke
    stroke.Parent = panel
    local title = Instance.new("TextLabel")
    title.Parent = panel
    title.Size = UDim2.new(1, 0, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = config.Text
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    local slider = Instance.new("Frame")
    slider.Parent = panel
    slider.Size = UDim2.new(1, -40, 0, 30)
    slider.Position = UDim2.new(0, 20, 0, 45)
    slider.BackgroundColor3 = self.theme.SliderTrack
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 6)
    sliderCorner.Parent = slider
    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = self.theme.SliderFill
    fill.BorderSizePixel = 0
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 6)
    fillCorner.Parent = fill
    local knob = Instance.new("TextButton")
    knob.Parent = slider
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0, -10, 0.5, -10)
    knob.Text = ""
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.AutoButtonColor = false
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob
    local inputBox = Instance.new("TextBox")
    inputBox.Parent = panel
    inputBox.Size = UDim2.new(0, 80, 0, 28)
    inputBox.Position = UDim2.new(0, 20, 0, 85)
    inputBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    inputBox.Text = tostring(defaultVal)
    inputBox.TextColor3 = Color3.new(1, 1, 1)
    inputBox.Font = Enum.Font.SourceSans
    inputBox.TextSize = 16
    local inputCorner = Instance.new("UICorner")
    inputCorner.CornerRadius = UDim.new(0, 6)
    inputCorner.Parent = inputBox
    local function updateDisplay(val)
        local percent = (val - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -10, 0.5, -10)
        inputBox.Text = tostring(math.floor(val))
    end
    local function setVal(val)
        val = math.clamp(math.floor(val), minVal, maxVal)
        currentVal = val
        updateDisplay(val)
        if onChange then onChange(val) end
    end
    local confirmBtn = Instance.new("TextButton")
    confirmBtn.Parent = panel
    confirmBtn.Size = UDim2.new(0, 80, 0, 28)
    confirmBtn.Position = UDim2.new(0, 110, 0, 85)
    confirmBtn.BackgroundColor3 = self.theme.ConfirmBtn
    confirmBtn.Text = "确认"
    confirmBtn.TextColor3 = Color3.new(1, 1, 1)
    confirmBtn.Font = Enum.Font.SourceSansBold
    confirmBtn.TextSize = 14
    local confirmCorner = Instance.new("UICorner")
    confirmCorner.CornerRadius = UDim.new(0, 6)
    confirmCorner.Parent = confirmBtn
    confirmBtn.MouseButton1Click:Connect(function()
        local num = tonumber(inputBox.Text)
        if num then setVal(num) end
        tweenPanelClose(panel)
    end)
    local resetBtn = Instance.new("TextButton")
    resetBtn.Parent = panel
    resetBtn.Size = UDim2.new(0, 80, 0, 28)
    resetBtn.Position = UDim2.new(0, 200, 0, 85)
    resetBtn.BackgroundColor3 = self.theme.ResetBtn
    resetBtn.Text = "重置"
    resetBtn.TextColor3 = Color3.new(1, 1, 1)
    resetBtn.Font = Enum.Font.SourceSansBold
    resetBtn.TextSize = 14
    local resetCorner = Instance.new("UICorner")
    resetCorner.CornerRadius = UDim.new(0, 6)
    resetCorner.Parent = resetBtn
    resetBtn.MouseButton1Click:Connect(function()
        setVal(defaultVal)
        tweenPanelClose(panel)
    end)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = panel
    closeBtn.Size = UDim2.new(0, 22, 0, 22)
    closeBtn.Position = UDim2.new(1, -26, 0, 6)
    closeBtn.BackgroundColor3 = self.theme.CloseBtn
    closeBtn.Text = "X"
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.SourceSansBold
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function()
        tweenPanelClose(panel)
    end)
    local dragging = false
    local UserInputService = game:GetService("UserInputService")
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderAbs = slider.AbsolutePosition
            local sliderSize = slider.AbsoluteSize
            local relativeX = math.clamp(mousePos.X - sliderAbs.X, 0, sliderSize.X)
            local percent = relativeX / sliderSize.X
            local newVal = math.floor(minVal + (maxVal - minVal) * percent)
            setVal(newVal)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    inputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local num = tonumber(inputBox.Text)
            if num then setVal(num) end
        end
    end)
    updateDisplay(defaultVal)
    return panel
end

function Page:AddPlayerSelector(config)
    local text = config.Text or "选择"
    local btn = self:AddButton({
        Text = text,
        Callback = function()
            self:ShowPlayerSelect(config.Callback)
        end
    })
    return btn
end

function Page:ShowPlayerSelect(onSelect)
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local selectGui = Instance.new("ScreenGui")
    selectGui.Name = "PlayerSelect"
    selectGui.Parent = LocalPlayer.PlayerGui
    selectGui.IgnoreGuiInset = true
    selectGui.ResetOnSpawn = false
    local bg = Instance.new("Frame")
    bg.Parent = selectGui
    bg.Size = UDim2.new(0, 220, 0, 300)
    bg.Position = UDim2.new(0.5, -110, 0.5, -150)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    bg.Visible = false
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = bg
    local title = Instance.new("TextLabel")
    title.Parent = bg
    title.Size = UDim2.new(1, 0, 0, 30)
    title.BackgroundTransparency = 1
    title.Text = "选择玩家"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Parent = bg
    scrollFrame.Size = UDim2.new(1, -10, 1, -80)
    scrollFrame.Position = UDim2.new(0, 5, 0, 35)
    scrollFrame.BackgroundTransparency = 1
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 4
    local playersList = Players:GetPlayers()
    local y = 0
    for _, p in ipairs(playersList) do
        if p ~= LocalPlayer then
            local pBtn = Instance.new("TextButton")
            pBtn.Parent = scrollFrame
            pBtn.Size = UDim2.new(1, -10, 0, 30)
            pBtn.Position = UDim2.new(0, 5, 0, y)
            pBtn.Text = p.Name
            pBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            pBtn.TextColor3 = Color3.new(1, 1, 1)
            pBtn.Font = Enum.Font.SourceSans
            pBtn.TextSize = 14
            local pCorner = Instance.new("UICorner")
            pCorner.CornerRadius = UDim.new(0, 6)
            pCorner.Parent = pBtn
            pBtn.MouseButton1Click:Connect(function()
                if onSelect then onSelect(p) end
                local closeTween = TweenService:Create(bg, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
                closeTween:Play()
                closeTween.Completed:Connect(function() selectGui:Destroy() end)
            end)
            y = y + 35
        end
    end
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, y)
    local cancelBtn = Instance.new("TextButton")
    cancelBtn.Parent = bg
    cancelBtn.Size = UDim2.new(1, -20, 0, 30)
    cancelBtn.Position = UDim2.new(0, 10, 1, -40)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    cancelBtn.Text = "取消"
    cancelBtn.TextColor3 = Color3.new(1, 1, 1)
    cancelBtn.Font = Enum.Font.SourceSansBold
    cancelBtn.TextSize = 14
    local cancelCorner = Instance.new("UICorner")
    cancelCorner.CornerRadius = UDim.new(0, 6)
    cancelCorner.Parent = cancelBtn
    cancelBtn.MouseButton1Click:Connect(function()
        local closeTween = TweenService:Create(bg, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
        closeTween:Play()
        closeTween.Completed:Connect(function() selectGui:Destroy() end)
    end)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = bg
    closeBtn.Size = UDim2.new(0, 30, 0, 20)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.Font = Enum.Font.SourceSansBold
    closeBtn.TextSize = 14
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function()
        local closeTween = TweenService:Create(bg, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
        closeTween:Play()
        closeTween.Completed:Connect(function() selectGui:Destroy() end)
    end)
    bg.Visible = true
    bg.Size = UDim2.new(0, 0, 0, 0)
    local openTween = TweenService:Create(bg, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 220, 0, 300)})
    openTween:Play()
end

function Page:CreateCoordPanel(config)
    local mainFrame = self:GetMain()
    local panel = Instance.new("Frame")
    panel.Name = "CoordPanel"
    panel.Parent = mainFrame
    panel.BackgroundColor3 = self.theme.PanelBg
    panel.BackgroundTransparency = 0.2
    panel.Visible = false
    panel.ZIndex = 200
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = panel
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = self.theme.PanelStroke
    stroke.Parent = panel
    local title = Instance.new("TextLabel")
    title.Parent = panel
    title.Size = UDim2.new(1, 0, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = config.Title or "实时坐标"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    local coordLabel = Instance.new("TextLabel")
    coordLabel.Name = "CoordText"
    coordLabel.Parent = panel
    coordLabel.Size = UDim2.new(1, -20, 0, 30)
    coordLabel.Position = UDim2.new(0, 10, 0, 40)
    coordLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    coordLabel.Text = "X: 0, Y: 0, Z: 0"
    coordLabel.TextColor3 = Color3.new(1, 1, 1)
    coordLabel.Font = Enum.Font.SourceSans
    coordLabel.TextSize = 14
    local coordCorner = Instance.new("UICorner")
    coordCorner.CornerRadius = UDim.new(0, 6)
    coordCorner.Parent = coordLabel
    local inputBox = Instance.new("TextBox")
    inputBox.Parent = panel
    inputBox.Size = UDim2.new(1, -20, 0, 28)
    inputBox.Position = UDim2.new(0, 10, 0, 80)
    inputBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    inputBox.PlaceholderText = "X Y Z 或 X,Y,Z"
    inputBox.TextColor3 = Color3.new(1, 1, 1)
    inputBox.Font = Enum.Font.SourceSans
    inputBox.TextSize = 14
    local inputCorner = Instance.new("UICorner")
    inputCorner.CornerRadius = UDim.new(0, 6)
    inputCorner.Parent = inputBox
    local teleportBtn = Instance.new("TextButton")
    teleportBtn.Parent = panel
    teleportBtn.Size = UDim2.new(0, 70, 0, 28)
    teleportBtn.Position = UDim2.new(0, 10, 0, 115)
    teleportBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    teleportBtn.Text = "传送"
    teleportBtn.TextColor3 = Color3.new(1, 1, 1)
    teleportBtn.Font = Enum.Font.SourceSansBold
    teleportBtn.TextSize = 14
    local teleportCorner = Instance.new("UICorner")
    teleportCorner.CornerRadius = UDim.new(0, 6)
    teleportCorner.Parent = teleportBtn
    local copyBtn = Instance.new("TextButton")
    copyBtn.Parent = panel
    copyBtn.Size = UDim2.new(0, 80, 0, 28)
    copyBtn.Position = UDim2.new(0, 90, 0, 115)
    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    copyBtn.Text = "复制坐标"
    copyBtn.TextColor3 = Color3.new(1, 1, 1)
    copyBtn.Font = Enum.Font.SourceSansBold
    copyBtn.TextSize = 14
    local copyCorner = Instance.new("UICorner")
    copyCorner.CornerRadius = UDim.new(0, 6)
    copyCorner.Parent = copyBtn
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = panel
    closeBtn.Size = UDim2.new(0, 22, 0, 22)
    closeBtn.Position = UDim2.new(1, -26, 0, 6)
    closeBtn.BackgroundColor3 = self.theme.CloseBtn
    closeBtn.Text = "X"
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.SourceSansBold
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() tweenPanelClose(panel) end)
    local function parseCoords(str)
        local parts = str:split(",")
        if #parts >= 3 then
            local x, y, z = tonumber(parts[1]), tonumber(parts[2]), tonumber(parts[3])
            if x and y and z then return x, y, z end
        end
        parts = str:split(" ")
        if #parts >= 3 then
            local x, y, z = tonumber(parts[1]), tonumber(parts[2]), tonumber(parts[3])
            if x and y and z then return x, y, z end
        end
        return nil
    end
    teleportBtn.MouseButton1Click:Connect(function()
        local input = inputBox.Text
        if input == "" or input:match("^%s*$") then
            if config.OnError then config.OnError("请输入坐标") end
            return
        end
        local x, y, z = parseCoords(input)
        if not x or not y or not z then
            if config.OnError then config.OnError("坐标格式错误") end
            return
        end
        if config.OnTeleport then config.OnTeleport(x, y, z) end
    end)
    local function updateCoordDisplay()
        if config.GetPosition then
            local pos = config.GetPosition()
            if pos then
                coordLabel.Text = string.format("X: %.1f, Y: %.1f, Z: %.1f", pos.X, pos.Y, pos.Z)
            end
        end
    end
    copyBtn.MouseButton1Click:Connect(function()
        if config.GetPosition then
            local pos = config.GetPosition()
            if pos then
                local coordText = string.format("%.1f,%.1f,%.1f", pos.X, pos.Y, pos.Z)
                if config.OnCopy then config.OnCopy(coordText) end
            end
        end
    end)
    local heartbeatConnection
    panel:GetPropertyChangedSignal("Visible"):Connect(function()
        if panel.Visible then
            updateCoordDisplay()
            if not heartbeatConnection then
                heartbeatConnection = game:GetService("RunService").Heartbeat:Connect(function()
                    if panel.Visible then updateCoordDisplay() end
                end)
            end
        else
            if heartbeatConnection then
                heartbeatConnection:Disconnect()
                heartbeatConnection = nil
            end
        end
    end)
    return panel
end

function Page:AddCoordPanel(config)
    config = config or {}
    local panel = nil
    local panelOpen = false
    local text = config.Text or "实时坐标"
    local targetSize = UDim2.new(0, 260, 0, 160)
    local targetPos = UDim2.new(0.5, -130, 0.5, -80)
    local btn = self:AddButton({
        Text = text,
        Callback = function()
            if not panel then
                panel = self:CreateCoordPanel(config)
                panel.Size = targetSize
                panel.Position = targetPos
            end
            if not panelOpen then
                tweenPanelOpen(panel, targetSize, targetPos)
                panelOpen = true
            else
                tweenPanelClose(panel)
                panelOpen = false
            end
        end
    })
    return btn
end

function Page:CreateAimbotPanel(config)
    local mainFrame = self:GetMain()
    local panel = Instance.new("Frame")
    panel.Name = "AimbotPanel"
    panel.Parent = mainFrame
    panel.BackgroundColor3 = self.theme.PanelBg
    panel.BackgroundTransparency = 0.2
    panel.Visible = false
    panel.ZIndex = 200
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = panel
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = self.theme.PanelStroke
    stroke.Parent = panel
    local title = Instance.new("TextLabel")
    title.Parent = panel
    title.Size = UDim2.new(1, 0, 0, 25)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = config.Title or "自瞄半径"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.Font = Enum.Font.SourceSansBold
    title.TextSize = 16
    local slider = Instance.new("Frame")
    slider.Parent = panel
    slider.Size = UDim2.new(1, -40, 0, 30)
    slider.Position = UDim2.new(0, 20, 0, 45)
    slider.BackgroundColor3 = self.theme.SliderTrack
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 6)
    sliderCorner.Parent = slider
    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = self.theme.SliderFill
    fill.BorderSizePixel = 0
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 6)
    fillCorner.Parent = fill
    local knob = Instance.new("TextButton")
    knob.Parent = slider
    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.Position = UDim2.new(0, -10, 0.5, -10)
    knob.Text = ""
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.AutoButtonColor = false
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob
    local minRadius = config.Min or 50
    local maxRadius = config.Max or 800
    local defaultRadius = config.Default or math.floor(game:GetService("Camera").ViewportSize.Y / 3)
    local currentRadius = defaultRadius
    local function updateSliderDisplay(val)
        local percent = (val - minRadius) / (maxRadius - minRadius)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -10, 0.5, -10)
    end
    local function setRadius(val)
        val = math.clamp(math.floor(val), minRadius, maxRadius)
        currentRadius = val
        updateSliderDisplay(val)
    end
    local confirmBtn = Instance.new("TextButton")
    confirmBtn.Parent = panel
    confirmBtn.Size = UDim2.new(0, 80, 0, 28)
    confirmBtn.Position = UDim2.new(0, 110, 0, 85)
    confirmBtn.BackgroundColor3 = self.theme.ConfirmBtn
    confirmBtn.Text = "确定"
    confirmBtn.TextColor3 = Color3.new(1, 1, 1)
    confirmBtn.Font = Enum.Font.SourceSansBold
    confirmBtn.TextSize = 14
    local confirmCorner = Instance.new("UICorner")
    confirmCorner.CornerRadius = UDim.new(0, 6)
    confirmCorner.Parent = confirmBtn
    confirmBtn.MouseButton1Click:Connect(function()
        if config.OnChange then config.OnChange(currentRadius) end
        tweenPanelClose(panel)
    end)
    local resetBtn = Instance.new("TextButton")
    resetBtn.Parent = panel
    resetBtn.Size = UDim2.new(0, 80, 0, 28)
    resetBtn.Position = UDim2.new(0, 200, 0, 85)
    resetBtn.BackgroundColor3 = self.theme.ResetBtn
    resetBtn.Text = "恢复默认"
    resetBtn.TextColor3 = Color3.new(1, 1, 1)
    resetBtn.Font = Enum.Font.SourceSansBold
    resetBtn.TextSize = 14
    local resetCorner = Instance.new("UICorner")
    resetCorner.CornerRadius = UDim.new(0, 6)
    resetCorner.Parent = resetBtn
    resetBtn.MouseButton1Click:Connect(function()
        setRadius(defaultRadius)
        if config.OnChange then config.OnChange(defaultRadius) end
        tweenPanelClose(panel)
    end)
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = panel
    closeBtn.Size = UDim2.new(0, 22, 0, 22)
    closeBtn.Position = UDim2.new(1, -26, 0, 6)
    closeBtn.BackgroundColor3 = self.theme.CloseBtn
    closeBtn.Text = "X"
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.SourceSansBold
    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 4)
    closeCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() tweenPanelClose(panel) end)
    local dragging = false
    local UserInputService = game:GetService("UserInputService")
    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderAbs = slider.AbsolutePosition
            local sliderSize = slider.AbsoluteSize
            local relativeX = math.clamp(mousePos.X - sliderAbs.X, 0, sliderSize.X)
            local percent = relativeX / sliderSize.X
            local newVal = math.floor(minRadius + (maxRadius - minRadius) * percent)
            setRadius(newVal)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    updateSliderDisplay(defaultRadius)
    return panel
end

function Page:AddAimbotPanel(config)
    config = config or {}
    local panel = nil
    local panelOpen = false
    local text = config.Text or "自瞄半径"
    local targetSize = UDim2.new(0, 250, 0, 160)
